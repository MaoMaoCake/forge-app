{
  "$schema": "https://raw.githubusercontent.com/grafana/grafana/main/docs/sources/developers/plugins/plugin.schema.json",
  "type": "app",
  "name": "Forge",
  "id": "maomaocake-forge-app",
  "backend": true,
  "executable": "gpx_forge",
  "info": {
    "keywords": ["app"],
    "description": "",
    "author": {
      "name": "Maomaocake"
    },
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "screenshots": [],
    "version": "%VERSION%",
    "updated": "%TODAY%"
  },
  "includes": [
    {
      "type": "page",
      "name": "Dashboard",
      "path": "/a/%PLUGIN_ID%/dashboard",
      "addToNav": true,
      "defaultNav": true
    },
    {
      "type": "page",
      "name": "Create Agent",
      "path": "/a/%PLUGIN_ID%/create",
      "role": "Admin",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "name": "Edit Agent",
      "path": "/a/%PLUGIN_ID%/config",
      "role": "Admin",
      "addToNav": true,
      "defaultNav": false
    },
    {
      "type": "page",
      "icon": "cog",
      "name": "Configuration",
      "path": "/plugins/%PLUGIN_ID%",
      "role": "Admin",
      "addToNav": true
    }
  ],
  "dependencies": {
    "grafanaDependency": ">=12.3.0",
    "plugins": []
  }
}
